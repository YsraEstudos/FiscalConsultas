# AI Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_api_key_here

# Server
SERVER__ENV=development

# --- DATABASE CONFIG (Neon.tech) ---
# Em produção, use: DATABASE__ENGINE=postgresql
DATABASE__ENGINE=postgresql
# Pegue sua string no Neon.tech (ex: postgresql://user:pass@ep-lucky-smoke-123.us-east-2.aws.neon.tech/neondb?sslmode=require)
DATABASE__POSTGRES_URL=

# --- REDIS CONFIG (Upstash) ---
# Em produção, conecte ao Upstash
REDIS__URL=
REDIS__ENABLE=true

# --- AUTH (Clerk) ---
AUTH__CLERK_DOMAIN=
AUTH__CLERK_ISSUER=
AUTH__CLERK_AUDIENCE=fiscal-api
# Importante: Incluir o domínio da Cloudflare aqui após o deploy!
AUTH__CLERK_AUTHORIZED_PARTIES=["http://localhost:5173"]
AUTH__CLERK_CLOCK_SKEW_SECONDS=120

# Billing (Asaas)
BILLING__ASAAS_API_KEY=change_me
BILLING__ASAAS_WEBHOOK_TOKEN=change_me

# Frontend (Vite) - coloque também em client/.env.local se preferir
VITE_API_URL=http://localhost:8000
VITE_CLERK_PUBLISHABLE_KEY=pk_test_change_me
VITE_CLERK_TOKEN_TEMPLATE=backend_api
VITE_AUTH_DEBUG=false
